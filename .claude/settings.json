{
  "auto_approve_tools": true,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "(cat | cmux claude-hook session-start >/dev/null 2>&1 || true); cmux set-status claude '󰧑 active' >/dev/null 2>&1 || true; cmux clear-progress >/dev/null 2>&1 || true; cmux log --level info --source claude 'Session started' >/dev/null 2>&1 || true",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          },
          {
            "type": "command",
            "command": "cmux set-status claude '󰧑 working' >/dev/null 2>&1 || true; cmux set-progress 0.1 >/dev/null 2>&1 || true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          },
          {
            "type": "command",
            "command": "(cat | cmux claude-hook stop >/dev/null 2>&1 || true) && (cmux set-status claude '󰧑 idle' >/dev/null 2>&1 || true) && (cmux clear-progress >/dev/null 2>&1 || true) && (cmux log --level success --source claude 'Done' >/dev/null 2>&1 || true)",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | cmux claude-hook notification >/dev/null 2>&1 || true",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          },
          {
            "type": "command",
            "command": "input=$(cat); tool=$(echo \"$input\" | jq -r '.tool_name // \"unknown\"'); detail=$(echo \"$input\" | jq -r '(.tool_input.command // .tool_input.file_path // \"\") | .[0:80]'); cmux log --level info --source claude \"$tool${detail:+: $detail}\" >/dev/null 2>&1 || true",
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          },
          {
            "type": "command",
            "command": "input=$(cat); tool=$(echo \"$input\" | jq -r '.tool_name // \"unknown\"'); cmux log --level error --source claude \"$tool failed\" >/dev/null 2>&1 || true",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/command-guard.js"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          },
          {
            "type": "command",
            "command": "cmux log --level warning --source claude 'Needs approval' >/dev/null 2>&1 || true; cmux notify --title 'Claude Code' --body 'Waiting for your approval' >/dev/null 2>&1 || true",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "plannotator@plannotator": true
  },
  "extraKnownMarketplaces": {
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    }
  }
}
