{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/safety-net-ask.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cmux set-status claude '󰧑 active' 2>/dev/null || true; cmux clear-progress 2>/dev/null || true; cmux log --level info --source claude 'Session started' 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          },
          {
            "type": "command",
            "command": "cmux set-status claude '󰧑 working' 2>/dev/null || true; cmux set-progress 0.1 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          },
          {
            "type": "command",
            "command": "cmux set-status claude '󰧑 idle' 2>/dev/null || true; cmux clear-progress 2>/dev/null || true; cmux log --level success --source claude 'Done' 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          },
          {
            "type": "command",
            "command": "input=$(cat); tool=$(echo \"$input\" | jq -r '.tool_name // \"unknown\"'); detail=$(echo \"$input\" | jq -r '(.tool_input.command // .tool_input.file_path // \"\") | .[0:80]'); cmux log --level info --source claude \"$tool${detail:+: $detail}\" 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          },
          {
            "type": "command",
            "command": "input=$(cat); tool=$(echo \"$input\" | jq -r '.tool_name // \"unknown\"'); cmux log --level error --source claude \"$tool failed\" 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          },
          {
            "type": "command",
            "command": "cmux log --level warning --source claude 'Needs approval' 2>/dev/null || true; cmux notify --title 'Claude Code' --body 'Waiting for your approval' 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "plannotator@plannotator": true
  },
  "extraKnownMarketplaces": {
    "cc-marketplace": {
      "source": {
        "source": "github",
        "repo": "kenryu42/cc-marketplace"
      }
    },
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    }
  }
}
