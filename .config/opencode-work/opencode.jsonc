{
    "$schema": "https://opencode.ai/config.json",
    "small_model": "github-copilot/gpt-5-mini",
    "agent": {
        "build": {
            "model": "github-copilot/claude-sonnet-4.6",
            "permission": {
                "bash": {
                    // GIT
                    "git commit*": "ask",
                    "git push*": "ask",
                    // anyscale auth
                    "anyscale login*": "ask",
                    "anyscale logout*": "ask",
                    // anyscale cloud (state-changing)
                    "anyscale cloud register*": "ask",
                    "anyscale cloud edit*": "ask",
                    "anyscale cloud update*": "ask",
                    "anyscale cloud delete*": "ask",
                    "anyscale cloud set-default*": "ask",
                    "anyscale cloud add-collaborators*": "ask",
                    "anyscale cloud setup*": "ask",
                    "anyscale cloud terminate-system-cluster*": "ask",
                    "anyscale cloud config*": "ask",
                    "anyscale cloud resource*": "ask",
                    // anyscale cluster (state-changing)
                    "anyscale cluster start*": "ask",
                    "anyscale cluster terminate*": "ask",
                    "anyscale cluster archive*": "ask",
                    // anyscale cluster-env (state-changing)
                    "anyscale cluster-env build*": "ask",
                    "anyscale cluster-env archive*": "ask",
                    // anyscale compute-config (state-changing)
                    "anyscale compute-config create*": "ask",
                    "anyscale compute-config archive*": "ask",
                    // anyscale image (state-changing)
                    "anyscale image build*": "ask",
                    "anyscale image register*": "ask",
                    // anyscale job (state-changing)
                    "anyscale job submit*": "ask",
                    "anyscale job terminate*": "ask",
                    "anyscale job archive*": "ask",
                    "anyscale job tags*": "ask",
                    // anyscale job-queue (state-changing)
                    "anyscale job-queue update*": "ask",
                    "anyscale job-queue tags*": "ask",
                    // anyscale machine (state-changing)
                    "anyscale machine delete*": "ask",
                    // anyscale machine-pool (state-changing)
                    "anyscale machine-pool create*": "ask",
                    "anyscale machine-pool delete*": "ask",
                    "anyscale machine-pool update*": "ask",
                    "anyscale machine-pool attach*": "ask",
                    "anyscale machine-pool detach*": "ask",
                    // anyscale organization-invitation (state-changing)
                    "anyscale organization-invitation create*": "ask",
                    "anyscale organization-invitation delete*": "ask",
                    // anyscale project (state-changing)
                    "anyscale project create*": "ask",
                    "anyscale project delete*": "ask",
                    "anyscale project add-collaborators*": "ask",
                    // anyscale resource-quota (state-changing)
                    "anyscale resource-quota create*": "ask",
                    "anyscale resource-quota delete*": "ask",
                    "anyscale resource-quota enable*": "ask",
                    "anyscale resource-quota disable*": "ask",
                    // anyscale schedule (state-changing)
                    "anyscale schedule apply*": "ask",
                    "anyscale schedule create*": "ask",
                    "anyscale schedule update*": "ask",
                    "anyscale schedule pause*": "ask",
                    "anyscale schedule resume*": "ask",
                    "anyscale schedule run*": "ask",
                    // anyscale service (state-changing)
                    "anyscale service deploy*": "ask",
                    "anyscale service rollout*": "ask",
                    "anyscale service rollback*": "ask",
                    "anyscale service terminate*": "ask",
                    "anyscale service delete*": "ask",
                    "anyscale service archive*": "ask",
                    "anyscale service tags*": "ask",
                    // anyscale service-account (state-changing)
                    "anyscale service-account create*": "ask",
                    "anyscale service-account create-api-key*": "ask",
                    "anyscale service-account delete*": "ask",
                    // anyscale user (state-changing)
                    "anyscale user batch-create*": "ask",
                    // anyscale workspace (state-changing)
                    "anyscale workspace tags*": "ask",
                    "anyscale workspace terminate*": "ask",
                    "anyscale workspace push*": "ask",
                    // anyscale workspace_v2 (state-changing)
                    "anyscale workspace_v2 create*": "ask",
                    "anyscale workspace_v2 update*": "ask",
                    "anyscale workspace_v2 start*": "ask",
                    "anyscale workspace_v2 terminate*": "ask",
                    "anyscale workspace_v2 push*": "ask",
                     "anyscale workspace_v2 run_command*": "ask",
                     // acli jira (state-changing)
                     "acli jira workitem create*": "ask",
                     "acli jira workitem edit*": "ask",
                     "acli jira workitem transition*": "ask",
                     "acli jira workitem assign*": "ask",
                     "acli jira workitem comment create*": "ask",
                     "acli jira workitem delete*": "ask",
                     "acli jira workitem link*": "ask",
                     "acli jira workitem unlink*": "ask",
                     "acli jira workitem label*": "ask",
                     "acli jira workitem vote*": "ask",
                     "acli jira workitem watch*": "ask",
                     "acli jira workitem move*": "ask",
                     "acli jira workitem clone*": "ask",
                     "acli jira sprint create*": "ask",
                     "acli jira sprint update*": "ask",
                     "acli jira sprint delete*": "ask",
                     "acli jira sprint close*": "ask",
                     "acli jira sprint start*": "ask",
                      "acli jira sprint move*": "ask",
                     // gh (state-changing)
                     "gh pr create*": "ask",
                     "gh pr merge*": "ask",
                     "gh pr close*": "ask",
                     "gh pr reopen*": "ask",
                     "gh pr edit*": "ask",
                     "gh pr review*": "ask",
                     "gh pr comment*": "ask",
                     "gh pr ready*": "ask",
                     "gh pr lock*": "ask",
                     "gh pr unlock*": "ask",
                     "gh release create*": "ask",
                     "gh release edit*": "ask",
                     "gh release delete*": "ask",
                     "gh release upload*": "ask",
                     "gh workflow run*": "ask",
                     "gh workflow enable*": "ask",
                     "gh workflow disable*": "ask",
                     "gh run rerun*": "ask",
                     "gh run cancel*": "ask",
                     "gh run delete*": "ask",
                     "gh repo create*": "ask",
                     "gh repo delete*": "ask",
                     "gh repo fork*": "ask",
                     "gh repo rename*": "ask",
                     "gh repo archive*": "ask",
                     "gh repo unarchive*": "ask",
                     "gh repo edit*": "ask",
                     "gh repo transfer*": "ask",
                     "gh repo deploy-key*": "ask",
                     "gh issue create*": "ask",
                     "gh issue close*": "ask",
                     "gh issue reopen*": "ask",
                     "gh issue edit*": "ask",
                     "gh issue comment*": "ask",
                     "gh issue pin*": "ask",
                     "gh issue unpin*": "ask",
                     "gh issue lock*": "ask",
                     "gh issue unlock*": "ask",
                     "gh issue delete*": "ask",
                     "gh issue transfer*": "ask",
                     "gh label create*": "ask",
                     "gh label edit*": "ask",
                     "gh label delete*": "ask",
                     "gh label clone*": "ask",
                     "gh secret set*": "ask",
                     "gh secret delete*": "ask",
                     "gh variable set*": "ask",
                     "gh variable delete*": "ask",
                     "gh env*": "ask",
                     "gh api*--method POST*": "ask",
                     "gh api*--method PUT*": "ask",
                     "gh api*--method PATCH*": "ask",
                     "gh api*--method DELETE*": "ask",
                     // gws (state-changing: any write method)
                     "gws auth login*": "ask",
                     "gws auth logout*": "ask",
                     "gws gmail users messages send*": "ask",
                     "gws gmail users messages insert*": "ask",
                     "gws gmail users messages delete*": "ask",
                     "gws gmail users messages batchDelete*": "ask",
                     "gws gmail users messages batchModify*": "ask",
                     "gws gmail users messages modify*": "ask",
                     "gws gmail users messages trash*": "ask",
                     "gws gmail users messages untrash*": "ask",
                     "gws gmail users messages import*": "ask",
                     "gws gmail users drafts create*": "ask",
                     "gws gmail users drafts update*": "ask",
                     "gws gmail users drafts delete*": "ask",
                     "gws gmail users drafts send*": "ask",
                     "gws gmail users labels create*": "ask",
                     "gws gmail users labels update*": "ask",
                     "gws gmail users labels patch*": "ask",
                     "gws gmail users labels delete*": "ask",
                     "gws gmail users threads delete*": "ask",
                     "gws gmail users threads modify*": "ask",
                     "gws gmail users threads trash*": "ask",
                     "gws gmail users threads untrash*": "ask",
                     "gws gmail users settings*": "ask",
                     "gws gmail users stop*": "ask",
                     "gws gmail users watch*": "ask",
                     "gws sheets spreadsheets create*": "ask",
                     "gws sheets spreadsheets batchUpdate*": "ask",
                     "gws sheets spreadsheets values update*": "ask",
                     "gws sheets spreadsheets values batchUpdate*": "ask",
                     "gws sheets spreadsheets values append*": "ask",
                     "gws sheets spreadsheets values clear*": "ask",
                     "gws sheets spreadsheets values batchClear*": "ask",
                     "gws sheets spreadsheets sheets*": "ask",
                     "gws sheets spreadsheets developerMetadata*": "ask",
                     // datadog API via curl (state-changing)
                     "curl*-X POST*api.datadoghq.com*": "ask",
                     "curl*-X PUT*api.datadoghq.com*": "ask",
                     "curl*-X PATCH*api.datadoghq.com*": "ask",
                     "curl*-X DELETE*api.datadoghq.com*": "ask"
                }
            }
        },
        "plan": {
            "model": "github-copilot/claude-opus-4.6",
            "thinking": {
                "type": "enabled",
                "budgetTokens": 16000
            }
        }
    },
    "plugin": [
        "cc-safety-net",
        //"@ramtinj95/opencode-tokenscope@latest",
        "@mohak34/opencode-notifier@latest",
        "@plannotator/opencode@latest",
        "opencode-cmux"
    ],
    "experimental": {
        "disable_paste_summary": true
    },
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": true
        },
        "playwright": {
            "type": "local",
            "command": ["npx", "-y", "@playwright/mcp@latest"],
            "enabled": true
        },
        "datadog": {
            "type": "local",
            "command": ["/Users/alexandre.mendonca/.local/bin/datadog_mcp_cli"],
            "enabled": true
        }
    }
}
