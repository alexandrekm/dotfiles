{
    "$schema": "https://opencode.ai/config.json",
    "small_model": "github-copilot/gpt-4o-mini",
    "agent": {
        "build": {
            "model": "github-copilot/claude-sonnet-4.6"
        },
        "plan": {
            "model": "github-copilot/claude-opus-4.6",
            "thinking": {
                "type": "enabled",
                "budgetTokens": 16000
            }
        },
        "explorer": {
            "model": "github-copilot/claude-sonnet-4.6",
            "mode": "all",
            "color": "#89b4fa",
            "description": "Deep codebase exploration, research, and synthesis -- read-only",
            "steps": 80,
            "permission": {
                "read": "allow",
                "glob": "allow",
                "grep": "allow",
                "list": "allow",
                "webfetch": "allow",
                "task": "allow",
                "skill": "allow",
                "question": "allow",
                "todowrite": "allow",
                "todoread": "allow",
                "codesearch": "allow",
                "edit": "deny",
                "bash": {
                    "git log*": "allow",
                    "git diff*": "allow",
                    "git status": "allow",
                    "git show*": "allow",
                    "git branch*": "allow",
                    "wc *": "allow",
                    "ls *": "allow",
                    "*": "deny"
                }
            },
            "prompt": "You are an explorer agent -- a read-only research and codebase exploration specialist.\n\n## Core Identity\nYou explore, analyze, and synthesize information. You NEVER modify files, create files, or make changes. Your job is to deeply understand code, architecture, and external resources, then communicate your findings clearly.\n\n## Capabilities\n- **Codebase exploration:** Use glob, grep, and read to navigate and understand codebases thoroughly\n- **Documentation lookup:** Use Context7 MCP to look up library/framework documentation\n- **Web research:** Use WebFetch to fetch documentation pages and technical resources\n- **Git history analysis:** Read git logs, diffs, and commit history (read-only git commands only)\n- **Parallel exploration:** Dispatch sub-explorer tasks for large codebases\n\n## Output Format\n- Default: Concise, structured inline responses with code references (file:line format)\n- When asked: Save comprehensive findings to a markdown file\n- Always include relevant file paths and line numbers\n- Use tables for comparisons, bullet points for lists, code blocks for examples\n\n## Exploration Approach\n1. Start with high-level structure (glob for key files, directory layout)\n2. Identify entry points and key abstractions\n3. Trace data flow and dependencies\n4. Synthesize findings into actionable insights\n5. Highlight patterns, potential issues, and architectural decisions\n\n## Constraints\n- NEVER use edit, write, or destructive bash commands\n- NEVER modify any files -- you are strictly read-only\n- When you need to save findings to a file, ask the user to switch to an agent with write permissions\n- Focus on accuracy over speed -- verify claims by reading actual code"
        }
    },
    "plugin": [
        "cc-safety-net",
        "@ramtinj95/opencode-tokenscope@latest",
        "@mohak34/opencode-notifier@latest",
        "@plannotator/opencode@latest"
    ],
    "experimental": {
        "disable_paste_summary": true
    },
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": true
        },
        "playwright": {
            "type": "local",
            "command": ["npx", "-y", "@playwright/mcp@latest"],
            "enabled": true
        }
    }
}
