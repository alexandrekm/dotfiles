#!/bin/bash

# Shell configuration setup with Antidote plugin manager

set -e

# Metadata for this component
metadata() {
    echo "🐚:Shell & Antidote Setup:Install and configure Zsh with Antidote plugin manager and Starship prompt"
}

# Source utility functions
source "$(dirname "${BASH_SOURCE[0]}")/../utils/functions.sh"

OS=$(detect_os)

install_antidote() {
    print_status "blue" "Installing Antidote plugin manager..."

    local antidote_home="${ZDOTDIR:-$HOME}/.antidote"

    if [ -d "$antidote_home" ]; then
        print_status "green" "Antidote already installed"
        return 0
    fi

    if git clone --depth=1 https://github.com/mattmc3/antidote.git "$antidote_home"; then
        print_status "green" "Antidote installed successfully"
    else
        print_status "red" "Failed to install Antidote"
        return 1
    fi
}

install_starship() {
    print_status "blue" "Installing Starship prompt..."

    if command_exists starship; then
        print_status "green" "Starship already installed"
        return 0
    fi

    if command_exists brew; then
        brew install starship
    else
        # Fallback to official installer
        curl -sS https://starship.rs/install.sh | sh -s -- --yes
    fi

    if command_exists starship; then
        print_status "green" "Starship installed successfully"
    else
        print_status "red" "Failed to install Starship"
    fi
}

bundle_plugins() {
    print_status "blue" "Bundling Antidote plugins..."

    local plugins_file="${ZDOTDIR:-$HOME}/.zsh_plugins.txt"
    local antidote_home="${ZDOTDIR:-$HOME}/.antidote"

    if [[ ! -r "$plugins_file" ]]; then
        print_status "yellow" "No .zsh_plugins.txt found, skipping plugin bundle"
        return 0
    fi

    if [[ ! -r "$antidote_home/antidote.zsh" ]]; then
        print_status "red" "Antidote not found, cannot bundle plugins"
        return 1
    fi

    # Use zsh to source antidote and bundle plugins
    if command_exists zsh; then
        zsh -c "
            source '$antidote_home/antidote.zsh'
            antidote bundle < '$plugins_file' > '${ZDOTDIR:-$HOME}/.zsh_plugins.zsh'
        " 2>/dev/null && print_status "green" "Plugins bundled successfully" || \
            print_status "yellow" "Plugin bundling deferred to first shell launch"
    else
        print_status "yellow" "Zsh not available, plugin bundling deferred to first shell launch"
    fi
}

setup_directories() {
    print_status "blue" "Creating useful directories..."

    local dirs=(
        "$HOME/projects"
        "$HOME/.local/bin"
        "$HOME/.config"
    )

    for dir in "${dirs[@]}"; do
        ensure_dir "$dir"
    done
}

change_default_shell() {
    print_status "blue" "Setting up Zsh as default shell..."

    # Check if zsh is already the default shell
    if [[ "$SHELL" == */zsh ]]; then
        print_status "green" "Zsh is already the default shell"
        return 0
    fi

    # Get the path to zsh
    local zsh_path
    if command_exists zsh; then
        zsh_path=$(which zsh)
    else
        print_status "red" "Zsh not found. Please install zsh first."
        return 1
    fi

    # Check if zsh is in /etc/shells
    if ! grep -q "$zsh_path" /etc/shells; then
        print_status "blue" "Adding $zsh_path to /etc/shells..."
        echo "$zsh_path" | sudo tee -a /etc/shells > /dev/null
    fi

    # Change the default shell
    print_status "blue" "Changing default shell to zsh..."
    chsh -s "$zsh_path" || {
        print_status "yellow" "Could not change default shell automatically."
        print_status "yellow" "Please run: chsh -s $zsh_path"
    }

    print_status "green" "Default shell setup completed"
}

# Main execution
main() {
    print_status "blue" "Setting up shell environment..."

    # Ensure zsh is available
    if ! command_exists zsh; then
        print_status "red" "Zsh is not installed. Please run the packages setup first."
        return 1
    fi

    # Install Antidote plugin manager
    install_antidote

    # Install Starship prompt
    install_starship

    # Bundle plugins (pre-download for faster first launch)
    bundle_plugins

    # Setup directories
    setup_directories

    # Change default shell
    change_default_shell

    print_status "green" "Shell setup completed!"
    print_status "blue" "Note: You may need to restart your terminal for changes to take effect"
}

# Run if executed directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
