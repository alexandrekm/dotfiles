#!/bin/bash

# Package management setup for different operating systems

set -e

# Metadata for this component
metadata() {
    echo "📦:Package Management Setup:Install package managers and essential development tools"
}

# Source utility functions
source "$(dirname "${BASH_SOURCE[0]}")/../utils/functions.sh"

OS=$(detect_os)

setup_package_manager() {
    print_status "blue" "Setting up package manager for $OS..."
    
    case $OS in
        "macos")
            setup_homebrew
            ;;
        "linux")
            setup_linux_packages
            setup_homebrew
            ;;
        *)
            print_status "red" "Unsupported operating system: $OS"
            exit 1
            ;;
    esac
}

setup_homebrew() {
    if ! command_exists brew; then
        print_status "blue" "Installing Homebrew..."
        # Use NONINTERACTIVE=1 to skip prompts if possible, or echo to skip the "press enter" prompt
        NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        
        # Add Homebrew to PATH based on OS and installation path
        if [[ "$OS" == "macos" ]]; then
            if [[ -f "/opt/homebrew/bin/brew" ]]; then
                eval "$(/opt/homebrew/bin/brew shellenv)"
            fi
        elif [[ "$OS" == "linux" ]]; then
            local brew_path=""
            if [[ -d "/home/linuxbrew/.linuxbrew" ]]; then
                brew_path="/home/linuxbrew/.linuxbrew"
            elif [[ -d "$HOME/.linuxbrew" ]]; then
                brew_path="$HOME/.linuxbrew"
            fi

            if [[ -n "$brew_path" ]]; then
                eval "$($brew_path/bin/brew shellenv)"
            fi
        fi
        print_status "green" "Homebrew installed successfully"
    else
        print_status "green" "Homebrew already installed"
    fi
}

setup_linux_packages() {
    local distro=$(get_linux_distro)
    print_status "blue" "Detected Linux distribution: $distro"
    
    case $distro in
        "ubuntu"|"debian")
            if command_exists apt-get; then
                print_status "blue" "Updating apt package lists..."
                sudo apt-get update
                
                print_status "blue" "Installing Homebrew dependencies..."
                sudo apt-get install -y build-essential procps curl file git
            fi
            ;;
        *)
            print_status "yellow" "Unknown Linux distribution, proceeding with caution..."
            ;;
    esac
}

install_essential_packages() {
    print_status "blue" "Installing essential packages..."
    
    case $OS in
        "macos")
            install_macos_packages
            ;;
        "linux")
            install_linux_essential_packages
            ;;
    esac
}

install_macos_packages() {
    local packages=(
        "neovim"
        "git"
        "curl"
        "wget"
        "tree"
        "jq"
        "zsh"
        "pinentry-mac"
        "gpg"
        "watch"
        "bat"
        "lsd"
        "dust"
        "duf"
        "broot"
        "atuin"
        "font-fira-code-nerd-font"
        "k9s"
        "fzf"
        "zoxide"
        "ripgrep"
        "yazi"
    )
    
    for package in "${packages[@]}"; do
        if ! brew list "$package" &> /dev/null; then
            print_status "blue" "Installing $package..."
            brew install "$package"
            
            # Remove default .zshrc if we just installed zsh, so yadm can manage it
            if [[ "$package" == "zsh" ]] && [[ -f "$HOME/.zshrc" ]]; then
                print_status "blue" "Removing default .zshrc to allow yadm management..."
                rm "$HOME/.zshrc"
            fi
        else
            print_status "green" "$package already installed"
        fi
    done
}

install_cmux() {
    if [[ "$OS" != "macos" ]]; then
        return 0
    fi

    # Terminal — cmux (Ghostty-based terminal with workspace management)
    if brew list --cask cmux &> /dev/null; then
        print_status "green" "cmux already installed"
    else
        print_status "blue" "Installing cmux..."
        brew tap manaflow-ai/cmux
        brew install --cask cmux
        print_status "green" "cmux installed successfully"
    fi

    if [[ ! -L /usr/local/bin/cmux ]]; then
        print_status "blue" "Creating cmux CLI symlink..."
        sudo ln -sf "/Applications/cmux.app/Contents/Resources/bin/cmux" /usr/local/bin/cmux
        print_status "green" "cmux CLI symlink created"
    else
        print_status "green" "cmux CLI symlink already exists"
    fi
}

install_linux_essential_packages() {
    local distro=$(get_linux_distro)
    
    case $distro in
        "ubuntu"|"debian")
            install_debian_packages
            ;;
        *)
            print_status "yellow" "Skipping package installation for unknown distribution"
            ;;
    esac
}

install_debian_packages() {
    local packages=(
        "neovim"
        "git"
        "curl"
        "wget"
        "tree"
        "jq"
        "ripgrep"
        "fd-find"
        "build-essential"
        "gpg"
        "zsh"
        "watch"
        "bat"
        "lsd"
        "duf"
        "zoxide"
    )
    
    for package in "${packages[@]}"; do
        if ! dpkg -l | grep -q "^ii  $package "; then
            print_status "blue" "Installing $package..."
            sudo apt-get install -y "$package"
            
            # Remove default .zshrc if we just installed zsh, so yadm can manage it
            if [[ "$package" == "zsh" ]] && [[ -f "$HOME/.zshrc" ]]; then
                print_status "blue" "Removing default .zshrc to allow yadm management..."
                rm "$HOME/.zshrc"
            fi
        else
            print_status "green" "$package already installed"
        fi
    done
    
    # Install dust for Linux (not available via apt)
    install_dust_linux

    # Install broot for Linux (not available via apt)
    install_broot_linux

    # Install atuin for Linux
    install_atuin_linux
    
    # Install k9s for Linux
    install_k9s_linux
    
    # Install FiraCode Nerd Font for Linux
    install_linux_nerd_font
}

install_dust_linux() {
    if command_exists dust; then
        print_status "green" "dust already installed"
        return 0
    fi

    print_status "blue" "Installing dust..."

    local install_dir="$HOME/.local/bin"
    mkdir -p "$install_dir"

    local arch=$(uname -m)
    case $arch in
        x86_64)  arch="x86_64" ;;
        aarch64|arm64) arch="aarch64" ;;
        *)
            print_status "red" "Unsupported architecture for dust: $arch"
            return 1
            ;;
    esac

    local temp_dir=$(mktemp -d)
    local dust_version
    dust_version=$(curl -fsSL https://api.github.com/repos/bootandy/dust/releases/latest | grep '"tag_name"' | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')

    local download_url="https://github.com/bootandy/dust/releases/download/${dust_version}/dust-${dust_version}-${arch}-unknown-linux-musl.tar.gz"

    curl -fsSL "$download_url" -o "$temp_dir/dust.tar.gz"

    if [[ $? -eq 0 ]]; then
        tar -xzf "$temp_dir/dust.tar.gz" -C "$temp_dir" --strip-components=1
        mv "$temp_dir/dust" "$install_dir/"
        chmod +x "$install_dir/dust"
        print_status "green" "dust installed successfully"
    else
        print_status "red" "Failed to download dust"
    fi

    rm -rf "$temp_dir"
}

install_broot_linux() {
    if command_exists broot; then
        print_status "green" "broot already installed"
        return 0
    fi

    print_status "blue" "Installing broot..."

    local install_dir="$HOME/.local/bin"
    mkdir -p "$install_dir"

    local arch=$(uname -m)
    local zip_arch
    case $arch in
        x86_64)  zip_arch="x86_64-unknown-linux-musl" ;;
        aarch64|arm64) zip_arch="aarch64-unknown-linux-musl" ;;
        *)
            print_status "red" "Unsupported architecture for broot: $arch"
            return 1
            ;;
    esac

    local broot_version
    broot_version=$(curl -fsSL https://api.github.com/repos/Canop/broot/releases/latest | grep '"tag_name"' | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')
    local broot_version_num="${broot_version#v}"

    local temp_dir=$(mktemp -d)
    local download_url="https://github.com/Canop/broot/releases/download/${broot_version}/broot_${broot_version_num}.zip"

    curl -fsSL "$download_url" -o "$temp_dir/broot.zip"

    if [[ $? -eq 0 ]]; then
        unzip -q "$temp_dir/broot.zip" "${zip_arch}/broot" -d "$temp_dir"
        mv "$temp_dir/${zip_arch}/broot" "$install_dir/broot"
        chmod +x "$install_dir/broot"
        print_status "green" "broot installed successfully"
    else
        print_status "red" "Failed to download broot"
    fi

    rm -rf "$temp_dir"
}

install_atuin_linux() {
    if command_exists atuin; then
        print_status "green" "atuin already installed"
        return 0
    fi
    
    print_status "blue" "Installing atuin..."
    
    # Install atuin using the official installer
    bash <(curl --proto '=https' --tlsv1.2 -sSf https://setup.atuin.sh)
    
    if command_exists atuin; then
        print_status "green" "atuin installed successfully"
    else
        print_status "red" "Failed to install atuin"
    fi
}

install_k9s_linux() {
    if command_exists k9s; then
        print_status "green" "k9s already installed"
        return 0
    fi
    
    print_status "blue" "Installing k9s..."
    
    local install_dir="$HOME/.local/bin"
    mkdir -p "$install_dir"
    
    # Detect architecture
    local arch=$(uname -m)
    case $arch in
        x86_64)
            arch="amd64"
            ;;
        aarch64|arm64)
            arch="arm64"
            ;;
        *)
            print_status "red" "Unsupported architecture: $arch"
            return 1
            ;;
    esac
    
    # Download and install k9s
    local temp_dir=$(mktemp -d)
    cd "$temp_dir"
    
    local k9s_version="v0.32.7"
    local download_url="https://github.com/derailed/k9s/releases/download/${k9s_version}/k9s_Linux_${arch}.tar.gz"
    
    curl -fsSL "$download_url" -o k9s.tar.gz
    
    if [[ $? -eq 0 ]]; then
        tar -xzf k9s.tar.gz k9s
        mv k9s "$install_dir/"
        chmod +x "$install_dir/k9s"
        
        if command_exists k9s; then
            print_status "green" "k9s installed successfully"
        else
            print_status "green" "k9s installed to $install_dir/k9s (add $install_dir to PATH if needed)"
        fi
    else
        print_status "red" "Failed to download k9s"
    fi
    
    # Cleanup
    cd - > /dev/null
    rm -rf "$temp_dir"
}

install_linux_nerd_font() {
    local font_dir="$HOME/.local/share/fonts"
    local font_name="FiraCode Nerd Font"
    
    # Check if font is already installed
    if fc-list | grep -i "fira.*code.*nerd" > /dev/null 2>&1; then
        print_status "green" "FiraCode Nerd Font already installed"
        return 0
    fi
    
    print_status "blue" "Installing FiraCode Nerd Font..."
    
    # Create fonts directory
    mkdir -p "$font_dir"
    
    # Download and install FiraCode Nerd Font
    local temp_dir=$(mktemp -d)
    cd "$temp_dir"
    
    curl -fsSL "https://github.com/ryanoasis/nerd-fonts/releases/download/v3.1.1/FiraCode.zip" -o FiraCode.zip
    
    if [[ $? -eq 0 ]]; then
        unzip -q FiraCode.zip -d "$font_dir/"
        
        # Refresh font cache
        fc-cache -fv > /dev/null 2>&1
        
        print_status "green" "FiraCode Nerd Font installed successfully"
    else
        print_status "red" "Failed to download FiraCode Nerd Font"
    fi
    
    # Cleanup
    cd - > /dev/null
    rm -rf "$temp_dir"
}



# Main execution
main() {
    setup_package_manager
    install_essential_packages
    install_cmux
    
    # Run OpenCode setup
    local script_dir="$(dirname "${BASH_SOURCE[0]}")"
    if [[ -f "$script_dir/opencode_setup" ]]; then
        "$script_dir/opencode_setup"
    else
        print_status "red" "OpenCode setup script not found at $script_dir/opencode_setup"
    fi

    print_status "green" "Package setup completed!"
}

# Run if executed directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
