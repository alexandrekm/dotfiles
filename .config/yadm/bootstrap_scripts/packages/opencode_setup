#!/bin/bash

# OpenCode setup script

set -e

# Metatdata for this component
metadata() {
    echo "🤖:OpenCode Setup:Install OpenCode and its plugins"
}

# Source utility functions
# Adjust relative path if this script moves. Assuming it's in the same dir as 'setup'.
source "$(dirname "${BASH_SOURCE[0]}")/../utils/functions.sh"

OS=$(detect_os)

setup_opencode() {
    print_status "blue" "Installing OpenCode..."
    brew install anomalyco/tap/opencode || true
}

install_opencode_global_packages() {
    print_status "blue" "Installing OpenCode global packages..."
    bun install -g cc-safety-net
}

install_plannotator() {
    if command_exists plannotator; then
        print_status "green" "plannotator already installed"
        return 0
    fi

    print_status "blue" "Installing plannotator..."
    curl -fsSL https://plannotator.ai/install.sh | bash

    if command_exists plannotator; then
        print_status "green" "plannotator installed successfully"
    else
        print_status "red" "Failed to install plannotator"
    fi
}

# Main execution
main() {
    setup_opencode
    install_opencode_global_packages
    install_plannotator
}

# Run if executed directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
