# -----------------------------------------------------------------------------
# Homebrew Setup
# -----------------------------------------------------------------------------
if [[ -f "/opt/homebrew/bin/brew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# -----------------------------------------------------------------------------
# PATH Configuration
# -----------------------------------------------------------------------------
export PATH="$PATH:${HOME}/bin"

# -----------------------------------------------------------------------------
# macOS Aliases
# -----------------------------------------------------------------------------
# Use bat instead of cat for better syntax highlighting
alias cat='bat --paging=never --style=plain'
alias less='bat'
alias more='bat'

# VS Code stable (explicit path avoids picking up Insiders or Cursor)
# Using a function instead of alias to correctly handle paths with spaces
code() {
  if [[ $# -eq 1 && -f "$1" ]]; then
    '/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code' "$(dirname "$1")" --goto "$1"
  else
    '/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code' "$@"
  fi
}
